#!/bin/bash
# meet — record meetings and transcribe them locally
# Usage: meet start [name]  — start recording
#        meet stop           — stop recording + transcribe
#        meet list           — list recordings
#        meet transcribe <file>  — transcribe an existing audio file

set -e

MEET_DIR="${MEET_DIR:-$HOME/src/hub/meetings/recordings}"
TRANSCRIPT_DIR="${MEET_DIR}/transcripts"
PID_FILE="/tmp/meet-recording.pid"
META_FILE="/tmp/meet-recording.meta"

# Audio device: use "Meet Recording" aggregate device if available, otherwise default mic
AUDIO_DEVICE="${MEET_DEVICE:-}"
if [ -z "$AUDIO_DEVICE" ]; then
  if system_profiler SPAudioDataType 2>/dev/null | grep -q "Meet Recording"; then
    AUDIO_DEVICE="Meet Recording"
  fi
fi

mkdir -p "$MEET_DIR" "$TRANSCRIPT_DIR"

# Colors
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m'

case "${1:-help}" in

  start)
    if [ -f "$PID_FILE" ]; then
      echo -e "${RED}Already recording.${NC} Run 'meet stop' first."
      exit 1
    fi

    NAME="${2:-meeting}"
    TIMESTAMP=$(date +%Y-%m-%d-%H%M)
    FILENAME="${TIMESTAMP}-${NAME}.wav"
    FILEPATH="${MEET_DIR}/${FILENAME}"

    echo -e "${GREEN}Recording:${NC} ${FILENAME}"

    # Auto-switch output to Meet Output so BlackHole captures call audio
    if command -v SwitchAudioSource &>/dev/null && [ -n "$AUDIO_DEVICE" ]; then
      PREV_OUTPUT=$(SwitchAudioSource -c -t output 2>/dev/null)
      echo "$PREV_OUTPUT" > /tmp/meet-prev-output
      if SwitchAudioSource -a -t output 2>/dev/null | grep -q "Meet Output"; then
        SwitchAudioSource -s "Meet Output" -t output &>/dev/null
        echo -e "${BLUE}Audio output:${NC} switched to Meet Output (auto)"
      fi
      echo -e "${BLUE}Audio input:${NC} ${AUDIO_DEVICE} (mic + system audio)"
    else
      echo -e "${YELLOW}Tip:${NC} No aggregate device found. Recording from default mic only."
      echo -e "     Set up 'Meet Recording' in Audio MIDI Setup for full call capture."
    fi
    echo ""
    echo -e "${BLUE}Press Ctrl+C or run 'meet stop' in another terminal to finish.${NC}"

    # Save metadata
    echo "$FILEPATH" > "$META_FILE"
    echo "$FILENAME" >> "$META_FILE"

    # Record using sox (coreaudio on macOS)
    if [ -n "$AUDIO_DEVICE" ]; then
      sox -t coreaudio "$AUDIO_DEVICE" -r 16000 -c 1 -b 16 "$FILEPATH" &
    else
      sox -d -r 16000 -c 1 -b 16 "$FILEPATH" &
    fi
    echo $! > "$PID_FILE"

    # Wait for the recording process
    wait $! 2>/dev/null || true

    # If we get here via Ctrl+C, clean up
    if [ -f "$PID_FILE" ]; then
      rm -f "$PID_FILE"
      # Restore audio output
      if command -v SwitchAudioSource &>/dev/null && [ -f /tmp/meet-prev-output ]; then
        PREV_OUTPUT=$(cat /tmp/meet-prev-output)
        SwitchAudioSource -s "$PREV_OUTPUT" -t output &>/dev/null
        rm -f /tmp/meet-prev-output
      fi
      echo ""
      echo -e "${GREEN}Recording saved:${NC} ${FILEPATH}"
      echo -e "Run ${BLUE}meet transcribe ${FILEPATH}${NC} to get the transcript."
      echo -e "Or run ${BLUE}meet stop${NC} for auto-transcription (if started in background)."
    fi
    ;;

  stop)
    if [ ! -f "$PID_FILE" ]; then
      echo -e "${RED}No active recording.${NC} Run 'meet start' first."
      exit 1
    fi

    PID=$(cat "$PID_FILE")
    FILEPATH=$(head -1 "$META_FILE")
    FILENAME=$(tail -1 "$META_FILE")

    # Stop recording
    kill "$PID" 2>/dev/null || true
    sleep 1
    rm -f "$PID_FILE" "$META_FILE"

    # Restore previous audio output
    if command -v SwitchAudioSource &>/dev/null && [ -f /tmp/meet-prev-output ]; then
      PREV_OUTPUT=$(cat /tmp/meet-prev-output)
      SwitchAudioSource -s "$PREV_OUTPUT" -t output &>/dev/null
      rm -f /tmp/meet-prev-output
      echo -e "${BLUE}Audio output:${NC} restored to ${PREV_OUTPUT}"
    fi

    echo -e "${GREEN}Recording stopped:${NC} ${FILEPATH}"

    # Check file exists and has content
    if [ ! -f "$FILEPATH" ] || [ ! -s "$FILEPATH" ]; then
      echo -e "${RED}Recording file is empty or missing.${NC}"
      exit 1
    fi

    DURATION=$(sox "$FILEPATH" -n stat 2>&1 | grep "Length" | awk '{print $3}' | cut -d. -f1)
    echo -e "${BLUE}Duration:${NC} ${DURATION}s"
    echo ""

    # Auto-transcribe
    echo -e "${YELLOW}Transcribing...${NC} (this takes roughly 1 min per 10 min of audio)"
    BASENAME=$(basename "$FILEPATH" .wav)
    mlx_whisper "$FILEPATH" \
      --model mlx-community/whisper-large-v3-turbo \
      --language en \
      --output-dir "$TRANSCRIPT_DIR" \
      --output-format txt 2>&1 | tail -3

    TRANSCRIPT="${TRANSCRIPT_DIR}/${BASENAME}.txt"
    if [ -f "$TRANSCRIPT" ]; then
      WORDS=$(wc -w < "$TRANSCRIPT")
      echo ""
      echo -e "${GREEN}Transcript saved:${NC} ${TRANSCRIPT}"
      echo -e "${BLUE}Words:${NC} ${WORDS}"
      echo ""
      echo -e "Preview:"
      head -10 "$TRANSCRIPT"
      echo "..."
    else
      echo -e "${RED}Transcription failed.${NC}"
    fi
    ;;

  transcribe)
    if [ -z "$2" ]; then
      echo "Usage: meet transcribe <audio-file>"
      exit 1
    fi

    INPUT="$2"
    if [ ! -f "$INPUT" ]; then
      echo -e "${RED}File not found:${NC} ${INPUT}"
      exit 1
    fi

    echo -e "${YELLOW}Transcribing:${NC} ${INPUT}"

    # Convert to wav if needed
    EXT="${INPUT##*.}"
    if [ "$EXT" != "wav" ]; then
      TMPWAV="/tmp/meet-convert-$$.wav"
      echo -e "${BLUE}Converting ${EXT} to wav...${NC}"
      ffmpeg -i "$INPUT" -ar 16000 -ac 1 -c:a pcm_s16le "$TMPWAV" -y 2>/dev/null
      INPUT="$TMPWAV"
    fi

    BASENAME=$(basename "$2" | sed 's/\.[^.]*$//')
    mlx_whisper "$INPUT" \
      --model mlx-community/whisper-large-v3-turbo \
      --language en \
      --output-dir "$TRANSCRIPT_DIR" \
      --output-format txt 2>&1 | tail -3

    # Clean up temp file
    [ -n "$TMPWAV" ] && rm -f "$TMPWAV"

    TRANSCRIPT="${TRANSCRIPT_DIR}/${BASENAME}.txt"
    if [ -f "$TRANSCRIPT" ]; then
      WORDS=$(wc -w < "$TRANSCRIPT")
      echo ""
      echo -e "${GREEN}Transcript saved:${NC} ${TRANSCRIPT}"
      echo -e "${BLUE}Words:${NC} ${WORDS}"
    fi
    ;;

  list)
    echo -e "${BLUE}Recordings:${NC}"
    ls -lh "$MEET_DIR"/*.wav 2>/dev/null || echo "  No recordings yet."
    echo ""
    echo -e "${BLUE}Transcripts:${NC}"
    ls -lh "$TRANSCRIPT_DIR"/*.txt 2>/dev/null || echo "  No transcripts yet."
    ;;

  devices)
    echo -e "${BLUE}Audio devices:${NC}"
    system_profiler SPAudioDataType 2>/dev/null | grep -E "^\s{8}\S" | sed 's/^        /  /'
    echo ""
    if [ -n "$AUDIO_DEVICE" ]; then
      echo -e "${GREEN}Meet will record from:${NC} ${AUDIO_DEVICE}"
    else
      echo -e "${YELLOW}Meet will record from:${NC} default microphone"
      echo -e "  Set up 'Meet Recording' aggregate device for full call capture."
    fi
    ;;

  help|*)
    echo ""
    echo "  meet — record meetings and transcribe them locally"
    echo ""
    echo "  Commands:"
    echo "    meet start [name]        Start recording (default name: meeting)"
    echo "    meet stop                Stop recording + auto-transcribe"
    echo "    meet transcribe <file>   Transcribe an existing audio/video file"
    echo "    meet list                List recordings and transcripts"
    echo "    meet devices             Show audio devices and recording source"
    echo ""
    echo "  Examples:"
    echo "    meet start mike-session-3"
    echo "    meet stop"
    echo "    meet transcribe ~/Downloads/call-recording.m4a"
    echo ""
    echo "  Environment:"
    echo "    MEET_DIR      Override recording directory (default: ~/src/hub/meetings/recordings)"
    echo "    MEET_DEVICE   Override audio device (default: auto-detect Meet Recording)"
    echo ""
    echo "  Recordings: ${MEET_DIR}"
    echo "  Transcripts: ${TRANSCRIPT_DIR}"
    echo ""
    ;;

esac
